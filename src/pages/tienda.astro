---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Footer from '@/components/Footer.astro';
import ProductCatalog from '@/islands/ProductCatalog';
import CartSidebar from '@/islands/CartSidebar';
import MascotGuide from '@/islands/MascotGuide';
import UserMenu from '@/islands/UserMenu';

export const prerender = false;

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, proxy-revalidate');
---

<BaseLayout
  title="Tienda Oficial | Puka Power - Elige tu Energía"
  description="Compra packs de Puka Power. Energía natural peruana a base de cáscara de café, camu camu y maca andina. Envío gratis en Lima."
  ogType="website"
>
  <header class="sticky top-0 z-50 bg-brand-secondary/95 backdrop-blur-md border-b border-brand-primary/10 py-4 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
      <div class="flex items-center space-x-6">
        <a
          href="/"
          class="hidden sm:flex items-center text-xs font-bold uppercase tracking-wider text-brand-dark/70 hover:text-brand-primary transition-all duration-300 group"
        >
          <svg class="w-4 h-4 mr-2 transition-transform duration-300 ease-out group-hover:-translate-x-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          <span class="transition-all duration-300 group-hover:opacity-80">Volver al inicio</span>
        </a>
        <a href="/tienda" class="flex items-center space-x-2">
          <span class="font-serif text-2xl sm:text-3xl font-extrabold tracking-wider text-brand-primary">PUKA POWER</span>
          <span class="text-xs bg-brand-accent/15 text-brand-accent font-bold px-2 py-0.5 rounded-full hidden md:inline-block">TIENDA</span>
        </a>
      </div>

      <div class="flex items-center space-x-3 sm:space-x-4">
        <a
          href="/juego"
          class="hidden sm:flex items-center space-x-1.5 px-3 py-1.5 bg-brand-accent/10 hover:bg-brand-accent/20 text-brand-accent font-bold text-[10px] uppercase tracking-widest rounded-xl transition-all duration-200 border border-brand-accent/20"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <span>Jugar y Ganar</span>
        </a>
        <UserMenu client:load />
        <a
          href="/"
          class="sm:hidden text-xs font-bold uppercase tracking-wider text-brand-dark/70 hover:text-brand-primary transition-colors"
        >
          <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Volver
        </a>
        <a href="#summary" class="relative p-2.5 bg-brand-primary/5 rounded-full hover:bg-brand-primary/10 transition-colors duration-200">
          <svg class="w-5 h-5 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/>
          </svg>
        </a>
      </div>
    </div>
  </header>

  <section class="py-10 bg-brand-secondary border-b border-brand-primary/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-3">
      <span class="text-brand-accent font-extrabold text-xs uppercase tracking-widest">⚡ Desbloquea tu potencial</span>
      <h1 class="font-serif text-4xl sm:text-5xl font-extrabold text-brand-primary">Elige tu Energía</h1>
      <p class="text-sm sm:text-base text-brand-dark/70 font-medium max-w-xl mx-auto">
        Ahorra más, rinde más. Selecciona tu pack ideal elaborado con súper alimentos del Perú.
      </p>
      <div class="w-12 h-1 bg-brand-accent mx-auto mt-2"></div>
    </div>
  </section>

  <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      <section class="lg:col-span-7" id="productos">
        <ProductCatalog client:load />
      </section>

      <section class="lg:col-span-5 lg:sticky lg:top-24" id="summary">
        <CartSidebar client:only="solid-js" />
      </section>
    </div>
  </main>

  <MascotGuide client:load autoShowDelay={5000} startIndex={5} enableCompanion={true} />
  <Footer />
</BaseLayout>
