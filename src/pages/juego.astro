---
import Advergame from '@/islands/Advergame';

export const prerender = false;
---
<!doctype html>
<html lang="es" class="m-0 p-0 w-full h-full overflow-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>¡Juega y Gana! | Puka Power</title>
    <meta name="description" content="Juega al reto Puka Power, recolecta monedas y gana un cupón de 15% de descuento." />
    <meta property="og:title" content="¡Juega y Gana! | Puka Power" />
    <meta property="og:description" content="Juega, gana y consigue tu cupón BOLT15 de 15% de descuento." />
    <meta property="og:type" content="website" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { width: 100%; height: 100%; overflow: hidden; background: #0f172a; }
      body { font-family: system-ui, -apple-system, sans-serif; -webkit-tap-highlight-color: transparent; }
    </style>
  </head>
  <body>
    <Advergame client:only="solid-js" />
  </body>
</html>
