---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Advergame from '@/islands/Advergame.tsx';

export const prerender = false;
---

<BaseLayout title="Arcade Oficial | Puka Power">
  <main class="w-full min-h-screen bg-slate-950 flex flex-col items-center justify-center overflow-hidden relative">
    <div class="w-full h-[85vh] md:h-[90vh] flex items-center justify-center relative z-10">
      <Advergame client:only="solid-js" />
    </div>
    <div class="fixed inset-0 z-50 bg-slate-950 text-white flex-col items-center justify-center p-6 text-center backdrop-blur-xl pointer-events-auto portrait:flex landscape:hidden">
      <div class="max-w-xs space-y-6">
        <div class="text-7xl">{'\u{1F4F1}'}</div>
        <h2 class="text-2xl font-black uppercase tracking-wider">Gira tu dispositivo</h2>
        <p class="text-base text-slate-400 leading-relaxed">Por favor, gira tu dispositivo a modo horizontal para disfrutar la experiencia Arcade Ninja</p>
        <div class="text-5xl animate-pulse text-yellow-400">{'\u21BB'}</div>
        <p class="text-xs text-slate-500">Modo horizontal requerido</p>
      </div>
    </div>
  </main>
</BaseLayout>
