---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SocialProof from '../components/SocialProof.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import Footer from '../components/Footer.astro';
import IngredientsViewer from '../islands/IngredientsViewer.tsx';
import QuickForm from '../islands/QuickForm.tsx';
import TrustBadges from '../components/TrustBadges.astro';
import MascotGuide from '../islands/MascotGuide.tsx';
---

<BaseLayout
  title="Puka Power | Energía Ancestral Peruana"
  description="El poder del rayo, ahora natural. Energía sostenida a base de cáscara de café, camu camu y maca andina. Sin químicos, sin bajones."
  ogType="website"
>
  <Header />

  <main>
    <Hero />
    <SocialProof />
    <Features />
    <IngredientsViewer client:load />

    <section id="testimonios">
      <Testimonials />
    </section>

    <section class="py-20 bg-wine-gradient text-brand-light relative overflow-hidden">
      <style>
        .bg-wine-gradient {
          background: linear-gradient(135deg, #7B1113 0%, #4A0507 100%);
        }
      </style>
      <div class="absolute inset-0 opacity-50 pointer-events-none bg-[radial-gradient(#FFF9F2_1px,transparent_1px)] bg-[length:16px_16px]"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
          <span class="text-brand-accentGold font-extrabold text-sm uppercase tracking-widest animate-pulse">⚡ Oferta Exclusiva de Lanzamiento</span>
          <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight">EMPIEZA TU CAMBIO AHORA</h2>
          <p class="text-brand-light/80 text-base sm:text-lg font-light">
            Únete a los miles de peruanos que ya desbloquearon su verdadero potencial.
          </p>
          <div class="w-16 h-1 bg-brand-accentGold mx-auto"></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-7 bg-brand-light text-brand-dark p-6 sm:p-10 rounded-3xl shadow-2xl border border-brand-light/20">
            <h3 class="font-serif text-2xl font-bold text-brand-primary mb-2">Completar Pedido Rápido</h3>
            <p class="text-xs text-brand-dark/60 uppercase font-bold tracking-wider mb-6">🔒 Pago y envío seguro contra entrega</p>
            <QuickForm client:load />
          </div>

          <div class="lg:col-span-5 flex flex-col items-center text-center space-y-6">
            <div class="bg-brand-light/10 p-8 rounded-3xl border border-brand-light/20 backdrop-blur-md w-full max-w-sm flex flex-col items-center">
              <h4 class="font-serif text-xl font-bold text-brand-accentGold mb-2">¿Prefieres comprar con QR?</h4>
              <p class="text-sm text-brand-light/80 mb-6">Escanea con Yape, Plin o tu banca móvil para obtener 15% de descuento directo en tu primer pedido.</p>

              <div class="bg-brand-light p-4 rounded-2xl shadow-xl w-48 h-48 flex items-center justify-center">
                <img
                  src="/sprites/qr-yape.webp"
                  alt="Código QR para pagar con Yape - Escanea para obtener 15% de descuento"
                  class="w-full h-full object-contain rounded-xl"
                  width="192"
                  height="192"
                  decoding="async"
                  loading="lazy"
                />
              </div>

              <p class="text-xs text-brand-light/60 font-bold mt-4 uppercase tracking-widest">Código: PUKAPOWER15</p>
            </div>

            <TrustBadges />
          </div>
        </div>
      </div>
    </section>
  </main>

  <MascotGuide client:load />
  <Footer />
</BaseLayout>

