---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthForms from '../../islands/AuthForms.tsx';

export const prerender = false;

// If already signed in, redirect to mi-cuenta
if (Astro.locals.user) {
  return Astro.redirect('/mi-cuenta');
}

const next = Astro.url.searchParams.get('next') || '/mi-cuenta';
const from = Astro.url.searchParams.get('from') || '';
---

<BaseLayout
  title="Inicia sesión | Puka Power"
  description="Ingresa a tu cuenta de Puka Power para ver tu historial de pedidos y obtener descuentos exclusivos."
  ogType="website"
>
  <main class="min-h-screen flex items-center justify-center px-4 py-12 relative overflow-hidden bg-gradient-to-br from-brand-wineDark via-brand-wine to-brand-wineDark">
    <!-- Decorative orbs (matches the brand gradient) -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <div class="absolute -top-32 -left-32 w-96 h-96 bg-brand-accent/15 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute -bottom-32 -right-32 w-96 h-96 bg-brand-accentGold/15 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s"></div>
    </div>

    <div class="relative w-full max-w-md">
      <a href="/" class="flex items-center gap-2 text-brand-cream/70 hover:text-brand-cream text-sm mb-6 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Volver al inicio
      </a>

      <AuthForms client:load mode="login" next={next} from={from} />
    </div>
  </main>
</BaseLayout>
