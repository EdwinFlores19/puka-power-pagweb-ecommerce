---
const features = [
  {
    title: '100% Ingredientes Reales',
    description: 'Sin conservadores agresivos, sin colorantes artificiales ni azúcar refinada añadida. Endulzado naturalmente con néctares de fruta que mantienen un índice glucémico controlado.',
    badge: 'Libre de transgénicos',
    icon: 'ingredients',
  },
  {
    title: 'Energía Sin Bajones',
    description: 'Olvídate del repentino colapso. La liberación lenta de cafeína proveniente de la cáscara de café proporciona un rendimiento lineal de hasta 6 horas consecutivas para tu estudio o trabajo.',
    badge: 'Sin efecto rebote',
    icon: 'energy',
  },
  {
    title: 'Amazonía y Andes',
    description: 'Nutrición ancestral de verdad. Extraído de forma directa y sostenible gracias a comunidades locales peruanas que cultivan el Camu Camu de la Amazonía y la Maca andina de los Andes.',
    badge: 'Comercio Justo Local',
    icon: 'globe',
  },
];
---

<section id="beneficios" class="py-20 bg-brand-secondary scroll-mt-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
      <span class="text-brand-accent font-extrabold text-xs uppercase tracking-widest">¿Por qué elegir natural?</span>
      <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-extrabold text-brand-primary">
        El problema no es la energía, es cómo la obtienes.
      </h2>
      <p class="text-base sm:text-lg text-brand-dark/70 font-medium">
        Dile adiós a las taquicardias y los bajones bruscos de azúcar. Nuestra fórmula inteligente está optimizada para el cerebro y el cuerpo.
      </p>
      <div class="w-16 h-1 bg-brand-accent mx-auto mt-4"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="bg-brand-light p-8 rounded-3xl border border-brand-primary/5 shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 flex flex-col justify-between">
          <div class="space-y-6">
            <div class="w-14 h-14 bg-brand-accent/10 rounded-2xl flex items-center justify-center text-brand-accent">
              {feature.icon === 'ingredients' && (
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
                </svg>
              )}
              {feature.icon === 'energy' && (
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              )}
              {feature.icon === 'globe' && (
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
                </svg>
              )}
            </div>
            <div class="space-y-3">
              <h3 class="font-serif text-xl sm:text-2xl font-bold text-brand-primary">{feature.title}</h3>
              <p class="text-sm sm:text-base text-brand-dark/85 leading-relaxed font-light">{feature.description}</p>
            </div>
          </div>
          <div class="pt-6 border-t border-brand-primary/5 mt-6">
            <span class="text-xs font-semibold text-brand-accent uppercase tracking-wider">{feature.badge}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
