---
import CartBadge from '../islands/CartBadge.tsx';
---

<header
  id="site-header"
  class="fixed top-0 left-0 w-full z-50 transition-all duration-300 bg-brand-secondary/95 backdrop-blur-md border-b border-brand-primary/10 py-4"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
    <a href="/" class="flex items-center space-x-2 focus:outline-none">
      <span class="font-serif text-2xl sm:text-3xl font-extrabold tracking-wider text-brand-primary">PUKA POWER</span>
      <span class="w-2.5 h-2.5 bg-brand-accent rounded-full animate-ping"></span>
    </a>

    <nav class="hidden md:flex space-x-8 items-center font-medium text-sm tracking-wide text-brand-dark">
      <a href="/#beneficios" class="hover:text-brand-primary transition-colors duration-200">Beneficios</a>
      <a href="/#ingredientes" class="hover:text-brand-primary transition-colors duration-200">Ingredientes</a>
      <a href="/#testimonios" class="hover:text-brand-primary transition-colors duration-200">Testimonios</a>
      <a href="/tienda" class="hover:text-brand-primary transition-colors duration-200 font-bold text-brand-accent">Ir a Tienda ⚡</a>
    </nav>

    <div class="flex items-center space-x-4">
      <a
        href="/tienda"
        class="hidden md:inline-flex px-6 py-2.5 bg-brand-accent text-brand-light font-bold text-xs uppercase tracking-widest rounded-full hover:bg-brand-accentGold transition-all duration-300 transform hover:-translate-y-0.5 shadow-lg shadow-brand-accent/20"
      >
        Comprar Ahora
      </a>
      <a href="/tienda" class="relative p-2.5 bg-brand-primary/5 rounded-full hover:bg-brand-primary/10 transition-colors duration-200">
        <svg class="w-5 h-5 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
        </svg>
        <CartBadge client:load />
      </a>
    </div>

    <button id="menu-btn" class="md:hidden flex flex-col justify-between w-6 h-4 text-brand-primary focus:outline-none" aria-label="Abrir Menú">
      <span class="w-full h-0.5 bg-brand-primary transition-all duration-300 origin-left" id="line1"></span>
      <span class="w-full h-0.5 bg-brand-primary transition-all duration-300" id="line2"></span>
      <span class="w-full h-0.5 bg-brand-primary transition-all duration-300 origin-left" id="line3"></span>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-brand-secondary/98 border-b border-brand-primary/10 shadow-xl transition-all duration-300">
    <nav class="flex flex-col space-y-4 px-6 py-8 font-medium text-lg text-brand-dark">
      <a href="/#beneficios" class="mobile-link hover:text-brand-primary transition-colors">Beneficios</a>
      <a href="/#ingredientes" class="mobile-link hover:text-brand-primary transition-colors">Ingredientes</a>
      <a href="/#testimonios" class="mobile-link hover:text-brand-primary transition-colors">Testimonios</a>
      <a href="/tienda" class="mobile-link hover:text-brand-accent transition-colors font-bold text-brand-accent">Ver Tienda 🛒</a>
      <a href="/tienda" class="mobile-link w-full text-center py-3 bg-brand-accent text-brand-light font-bold text-sm uppercase tracking-widest rounded-lg shadow-lg hover:bg-brand-accentGold">
        Comprar Ahora
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  let ticking = false;

  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        if (window.scrollY > 20) {
          header.classList.add('py-2', 'shadow-md', 'bg-brand-secondary/98');
          header.classList.remove('py-4');
        } else {
          header.classList.add('py-4');
          header.classList.remove('py-2', 'shadow-md', 'bg-brand-secondary/98');
        }
        ticking = false;
      });
      ticking = true;
    }
  });

  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const line1 = document.getElementById('line1');
  const line2 = document.getElementById('line2');
  const line3 = document.getElementById('line3');

  let menuOpen = false;
  menuBtn.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menuOpen) {
      mobileMenu.classList.remove('hidden');
      line1.style.transform = 'rotate(45deg) translate(2px, -1px)';
      line2.style.opacity = '0';
      line3.style.transform = 'rotate(-45deg) translate(2px, 1px)';
    } else {
      mobileMenu.classList.add('hidden');
      line1.style.transform = 'none';
      line2.style.opacity = '1';
      line3.style.transform = 'none';
    }
  });

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      line1.style.transform = 'none';
      line2.style.opacity = '1';
      line3.style.transform = 'none';
      menuOpen = false;
    });
  });
</script>
