---
const quickLinks = [
  { label: 'Sobre Nosotros', href: '/#beneficios' },
  { label: 'Sostenibilidad', href: '/#ingredientes' },
  { label: 'Comprar', href: '/tienda' },
  { label: 'Puntos de Venta', href: '#' },
];

const legalLinks = [
  { label: 'Términos y Condiciones', href: '#' },
  { label: 'Políticas de Privacidad', href: '#' },
  { label: 'Libro de Reclamaciones', href: '#' },
  { label: 'Preguntas Frecuentes', href: '#' },
];
---

<footer class="bg-brand-dark text-brand-light py-12 border-t border-brand-primary/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="space-y-4 col-span-1 md:col-span-2">
        <span class="font-serif text-2xl font-black text-brand-light tracking-widest">PUKA POWER</span>
        <p class="text-sm text-brand-light/60 font-light leading-relaxed max-w-sm">
          Nuestra misión es empoderar a cada peruano a conquistar sus metas con energía pura proveniente de la biodiversidad de nuestra tierra.
        </p>
        <div class="flex space-x-4 pt-2">
          <a href="#" class="hover:text-brand-accent transition-colors" aria-label="Facebook">
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
              <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/>
            </svg>
          </a>
          <a href="#" class="hover:text-brand-accent transition-colors" aria-label="Instagram">
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="font-serif text-sm font-bold uppercase tracking-widest text-brand-accentGold mb-4">La Compañía</h4>
        <ul class="space-y-2 text-sm text-brand-light/75">
          {quickLinks.map((link) => (
            <li><a href={link.href} class="hover:text-brand-accent transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-serif text-sm font-bold uppercase tracking-widest text-brand-accentGold mb-4">Soporte y Legal</h4>
        <ul class="space-y-2 text-sm text-brand-light/75">
          {legalLinks.map((link) => (
            <li><a href={link.href} class="hover:text-brand-accent transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-brand-light/10 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex space-x-4 text-2xl">
        <svg class="w-10 h-7 text-brand-light/30 hover:text-brand-light/70 transition-colors" viewBox="0 0 50 30" fill="currentColor">
          <rect width="50" height="30" rx="4" fill="currentColor" opacity="0.1"/>
          <text x="8" y="20" font-size="12" font-weight="bold" fill="currentColor">VISA</text>
        </svg>
        <svg class="w-10 h-7 text-brand-light/30 hover:text-brand-light/70 transition-colors" viewBox="0 0 50 30" fill="currentColor">
          <rect width="50" height="30" rx="4" fill="currentColor" opacity="0.1"/>
          <text x="3" y="20" font-size="10" font-weight="bold" fill="currentColor">MC</text>
        </svg>
        <svg class="w-10 h-7 text-brand-light/30 hover:text-brand-light/70 transition-colors" viewBox="0 0 50 30" fill="currentColor">
          <rect width="50" height="30" rx="4" fill="currentColor" opacity="0.1"/>
          <text x="4" y="20" font-size="10" font-weight="bold" fill="currentColor">AMEX</text>
        </svg>
        <svg class="w-10 h-7 text-brand-light/30 hover:text-brand-light/70 transition-colors" viewBox="0 0 24 24" fill="currentColor">
          <path d="M21 6H3a1 1 0 00-1 1v10a1 1 0 001 1h18a1 1 0 001-1V7a1 1 0 00-1-1zm-4 8H7v-4h10v4z" opacity="0.5"/>
          <rect x="8" y="9" width="8" height="2" rx="1" fill="currentColor" opacity="0.8"/>
        </svg>
      </div>
      <div class="text-xs text-brand-light/50 text-center sm:text-right">
        <p>© 2026 Puka Power. Todos los derechos reservados.</p>
        <p class="mt-1">Hecho con <span class="text-brand-accent">♥</span> en Lima, Perú.</p>
      </div>
    </div>
  </div>
</footer>
